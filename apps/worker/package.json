{
  "name": "@atlas/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@atlas/database": "0.1.0",
    "@atlas/integrations": "0.1.0",
    "@atlas/shared": "0.1.0",
    "cron-parser": "5.6.2",
    "pg-boss": "12.26.0",
    "pino": "^9.14.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
