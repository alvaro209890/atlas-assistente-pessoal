{
  "name": "@atlas/integrations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@atlas/shared": "0.1.0",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "openai": "6.46.0",
    "pino": "^9.14.0",
    "qrcode": "^1.5.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
