# Runtime
NODE_ENV=development
PORT=3000
WEB_ORIGIN=http://localhost:5173
TZ=America/Sao_Paulo

# PostgreSQL
POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_local
DATABASE_URL=postgresql://atlas:atlas_local@localhost:5432/atlas

# Basic account sessions (replace before using outside localhost)
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_NAME=atlas_session
SESSION_TTL_DAYS=30

# DeepSeek - one server-side platform key
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_OUTPUT_TOKENS=4096
MEMORY_CONFIDENCE_THRESHOLD=0.60
DEEPSEEK_TIMEOUT_MS=90000
AI_CONFIDENCE_THRESHOLD=0.70
RUN_LIVE_AI_TESTS=0

# Trello delegated authorization
TRELLO_API_KEY=
TRELLO_CALLBACK_URL=http://localhost:3000/api/trello/callback

# WhatsApp / Baileys
# Authentication state is stored per user in PostgreSQL.
BATCH_QUIET_SECONDS=10
BATCH_MAX_SECONDS=30
# Após este período sem mensagens, o próximo lote inicia uma nova conversa de
# contexto. O conhecimento durável continua disponível por meio do grafo.
CONVERSATION_CONTEXT_IDLE_MINUTES=15
# Orçamento do contexto de triagem, antes do envio ao provedor de IA.
AI_CONTEXT_MAX_MESSAGES=20
AI_CONTEXT_MAX_CHARS=18000
SESSION_WATCH_INTERVAL_SECONDS=15

# Frontend development proxy
VITE_API_URL=/api
